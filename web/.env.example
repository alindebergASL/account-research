ANTHROPIC_API_KEY=sk-ant-...

# Fail-closed master switch for every provider-backed request and queued job.
# The only enabling value is exactly "1"; unset/0/true remain disabled.
PROVIDER_CALLS_ENABLED=0

# First-run admin seed. Required ONLY when the users table is empty (fresh DB).
# After the admin row exists you can remove these from the environment.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-on-first-run
